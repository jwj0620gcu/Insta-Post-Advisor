# === LLM 설정 ===
# LLM 제공업체 선택: openai (기본) | anthropic | gemini
LLM_PROVIDER=openai

# OpenAI 설정 (LLM_PROVIDER=openai 시 필요)
# API Key는 OPENAI_API_KEY에 입력 (OPENAI_BASE_URL에 넣지 말 것)
OPENAI_API_KEY=sk-your-openai-key-here
# 비워두면 공식 https://api.openai.com/v1 사용
# OpenAI 호환 게이트웨이 사용 시 주소를 입력하세요:
# OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
OPENAI_BASE_URL=

# 모델명 (사용하는 제공업체에 맞게 설정)
# OpenAI: gpt-4o, gpt-4o-mini
# Claude: claude-sonnet-4-6, claude-haiku-4-5-20251001
# Gemini: gemini-2.0-flash, gemini-1.5-pro
LLM_MODEL=gpt-4o

# 세 가지 모델 티어 (미설정 시 LLM_MODEL 또는 아래 기본값 사용)
# LLM_MODEL_FAST=gpt-4o-mini       # 빠른 작업 (토론, 댓글 생성)
# LLM_MODEL_PRO=gpt-4o             # 심층 분석 (에이전트 진단, 심사)
# LLM_MODEL_OMNI=gpt-4o            # 멀티모달 (이미지/영상 이해)

# Agent LLM 출력 token 상한 (기본 2048)
# LLM_MAX_COMPLETION_TOKENS=2048
# 종합 심사관 출력 token 상한 (기본 6144; 짧으면 JSON 파싱 실패)
# JUDGE_MAX_COMPLETION_TOKENS=6144
# 시각 진단가 멀티모달 출력 token 상한 (기본 2500)
# VISUAL_AGENT_MAX_COMPLETION_TOKENS=2500

# LLM 샘플링 온도 (기본 0 = 결정적)
# LLM_TEMPERATURE=0
# 재현 가능한 시드 (일부 게이트웨이/모델 미지원 시 무시됨)
# LLM_SEED=
# 게이트웨이가 response_format=json_object를 미지원 시 1로 설정
# LLM_SKIP_JSON_RESPONSE_FORMAT=1

# Rate limit 재시도 횟수 (기본 2)
# LLM_RATE_LIMIT_RETRIES=2
# Rate limit 백오프 대기 시간 (초, 기본 1.2)
# LLM_RATE_LIMIT_BACKOFF_SEC=1.2

# 무료 티어 모드: 토론 단계 생략으로 API 호출 수 절감 (Gemini 무료 플랜 권장)
# LLM_FREE_TIER_MODE=0

# 단일 Agent 타임아웃 (초, 기본 90)
# AGENT_LLM_TIMEOUT_SEC=90
# 토론 단계 타임아웃 (초, 기본 90)
# DEBATE_LLM_TIMEOUT_SEC=90
# 종합 심사 타임아웃 (초, 기본 180)
# JUDGE_LLM_TIMEOUT_SEC=180

# === Anthropic 설정 (LLM_PROVIDER=anthropic 시 필요) ===
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# === Gemini 설정 (LLM_PROVIDER=gemini 시 필요) ===
# GEMINI_API_KEY=AIza-your-google-ai-studio-key-here

# === 이미지/영상 분석 설정 ===
# 멀티모달 커버 이미지 최대 장변 픽셀 (기본 1280, 범위 [256, 4096])
# VISION_MAX_EDGE=1280
# JPEG 압축 품질 (기본 85, 범위 [60, 95])
# VISION_JPEG_QUALITY=85

# === 서버 설정 ===
BACKEND_PORT=8001
FRONTEND_PORT=5173

# 허용 CORS 출처 (쉼표 구분, 미설정 시 localhost만 허용)
# 프로덕션 배포 시 반드시 설정 필요
# ALLOWED_ORIGINS=https://instarx.app,https://www.instarx.app
ALLOWED_ORIGINS=

# === 영상 업로드 설정 ===
# 영상 업로드 단일 파일 상한 (MB, 기본 300, 상한 1024)
# 변경 시 frontend/src/components/UploadZone.tsx의 VIDEO_MAX_MB도 함께 수정
# MAX_VIDEO_UPLOAD_MB=300

# === 영상 이해 (video_url 방식 — Gemini 또는 MiMo 게이트웨이) ===
# 모델이 공개 URL로 영상을 가져오므로 localhost 환경에서는 동작하지 않습니다.
#
# 방법 1) 명시적 공개 API 루트 주소 설정 (권장):
#   MIMO_VIDEO_PUBLIC_BASE_URL=https://api.yourdomain.com
# 방법 2) Nginx/Caddy 리버스 프록시에서 헤더 주입:
#   proxy_set_header X-Forwarded-Proto $scheme;
#   proxy_set_header X-Forwarded-Host $host;
#
# 미설정 시 첫 프레임 추출 + 이미지 이해로 폴백됩니다.
# /api/video-public-url-health 엔드포인트로 현재 상태 확인 가능.
MIMO_VIDEO_PUBLIC_BASE_URL=

# 임시 영상 URL HMAC 서명 키 (프로덕션에서 반드시 긴 랜덤 문자열로 교체)
TEMP_VIDEO_SIGNING_KEY=change-me-to-a-long-random-secret
# 임시 영상 URL 유효 기간 (초, 기본 900 = 15분)
TEMP_VIDEO_TTL_SECONDS=900
# 임시 영상 저장 경로 (기본: backend/data/temp_videos)
# TEMP_VIDEO_DIR=backend/data/temp_videos

# === 영상 음성 변환 (STT) ===
# ffmpeg이 시스템에 설치되어 있어야 합니다.
# 기본 활성화 (0으로 비활성화 가능):
# VIDEO_STT_ENABLED=1
#
# OpenAI Whisper 사용 시:
# OPENAI_WHISPER_BASE_URL=https://api.openai.com/v1
# OPENAI_WHISPER_API_KEY=sk-...
# WHISPER_MODEL=whisper-1
#
# 변환 언어 (기본 ko; 빈칸이면 language 파라미터 미전송)
# VIDEO_STT_LANGUAGE=ko
# 오디오 최대 길이 (초, 기본 3600)
# VIDEO_STT_MAX_AUDIO_SECONDS=3600
# 분할 변환 단위 (초, 기본 480)
# VIDEO_STT_SEGMENT_SECONDS=480
# STT HTTP 타임아웃 (초, 기본 240)
# VIDEO_STT_TIMEOUT_SEC=240
